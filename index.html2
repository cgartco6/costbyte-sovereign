<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="stylesheet" href="assets/sovereign.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap" rel="stylesheet">
    <title>CostByte Sovereign | Industrial Venture Production</title>
</head>
<body>
    <nav class="shop-nav">
        <div class="container nav-flex">
            <a href="index.html" class="logo">COSTBYTE SOVEREIGN</a>
            <div class="nav-links">
                <a href="#studios" class="btn-outline-white-sm">INDUSTRIAL STUDIOS</a>
                <a href="#tiers" class="btn-navy-sm">PRODUCTION TIERS</a>
            </div>
        </div>
    </nav>

    <header class="hero-mask">
        <div class="container">
            <div class="hero-content">
                <p class="brand-tag">SURGICAL DESIGN. AGGRESSIVE MARKETING.</p>
                <h1 class="main-title">Build. Brand. <span>Sovereign</span>.</h1>
                <p class="subtitle">Deploy 1,000-node aggressive marketing and professional generative design in minutes. High-enterprise aesthetics for real-world deployment of business assets.</p>
                <div class="hero-actions">
                    <a href="#tiers" class="btn-gold">VIEW PRODUCTION TIERS</a>
                    <a href="#studios" class="btn-outline-white">EXPLORE STUDIOS</a>
                </div>
            </div>
        </div>
    </header>

    <section class="demo-section">
        <div class="container">
            <div class="demo-box">
                <div class="demo-visual">
                    <div class="loader-ring"></div>
                    <p class="loader-text">WEAVING BRAND DNA...</p>
                </div>
                <div class="demo-info">
                    <h3>Sovereign Engine: Status Active</h3>
                    <p>Our autonomous swarm identifies high-conversion hooks. Currently targeting <strong>750 impulse buyers</strong> for the active 48-hour sprint. Surgical compliance audits active.</p>
                </div>
            </div>
        </div>
    </section>

    <div id="tiers" class="container" style="padding-top: 100px;">
        <h2 class="section-label">PRODUCTION TIERS</h2>
        <div class="grid">
            <div class="card">
                <h3>INCUBATOR</h3>
                <h2 class="price">FREE</h2>
                <ul class="features">
                    <li>Basic Digital Architecture</li>
                    <li>Surgical Brand Plan</li>
                </ul>
                <button onclick="initiatePayment('FREE', 0)" class="btn-outline">START GENESIS</button>
            </div>
            <div class="card premium">
                <div class="tag">ACTIVE GROWTH</div>
                <h3>BRONZE PACKAGE</h3>
                <h2 class="price">R300.00</h2>
                <ul class="features">
                    <li>100 Generative Ads (HD)</li>
                    <li>100-Node Marketing Swarm</li>
                </ul>
                <button onclick="initiatePayment('BRONZE', 300)" class="btn-navy">INITIATE DEPLOYMENT</button>
            </div>
            <div class="card gold">
                <div class="tag">ADDICTIVE</div>
                <h3>GOLD PACKAGE</h3>
                <h2 class="price">R750.00</h2>
                <ul class="features">
                    <li>500-Node Marketing Swarm</li>
                    <li>Full Design & Branding Studio</li>
                </ul>
                <button onclick="initiatePayment('GOLD', 750)" class="btn-gold">ACTIVATE GOLD</button>
            </div>
            <div class="card alpha">
                <div class="tag">ENTERPRISE DOMINANCE</div>
                <h3>PLATINUM SUITE</h3>
                <h2 class="price">R1,500.00</h2>
                <ul class="features">
                    <li>1,000-Node Aggressive Swarm</li>
                    <li>Infinite Studio Access</li>
                </ul>
                <button onclick="initiatePayment('PLATINUM', 1500)" class="btn-gold">DOMINATE MARKET</button>
            </div>
        </div>
    </div>

    <div id="studios" class="container" style="padding: 100px 0;">
        <h2 class="section-label">INDUSTRIAL STUDIOS (STANDALONE)</h2>
        <div class="grid">
            <div class="card">
                <h3>Design Studio</h3>
                <h2 class="price-sm">R500.00</h2>
                <p>Surgical UI/UX Production.</p>
                <button onclick="initiatePayment('DESIGN_STUDIO', 500)" class="btn-navy-sm">ACCESS STUDIO</button>
            </div>
            <div class="card">
                <h3>Branding Studio</h3>
                <h2 class="price-sm">R450.00</h2>
                <p>Industrial Brand DNA & Logos.</p>
                <button onclick="initiatePayment('BRAND_STUDIO', 450)" class="btn-navy-sm">ACCESS STUDIO</button>
            </div>
            <div class="card">
                <h3>Marketing Studio</h3>
                <h2 class="price-sm">R600.00</h2>
                <p>Conversion-Optimized Funnels.</p>
                <button onclick="initiatePayment('MARKETING_STUDIO', 600)" class="btn-navy-sm">ACCESS STUDIO</button>
            </div>
            <div class="card agg">
                <div class="tag">HIGH POWER</div>
                <h3>Aggressive Engine</h3>
                <h2 class="price-sm">R1,200.00</h2>
                <p>1,000-Node Social Saturation.</p>
                <button onclick="initiatePayment('AGG_ENGINE', 1200)" class="btn-gold">DEPLOY ENGINE</button>
            </div>
        </div>
    </div>

    <footer style="padding: 80px 0; background: #000; color: #444; text-align: center;">
        <div class="container">
            <p style="letter-spacing: 2px; font-weight: 800; color: #fff; margin-bottom: 20px;">COSTBYTE SOVEREIGN</p>
            <p>&copy; 2026. ALL RIGHTS RESERVED. POPIA & GDPR COMPLIANT.</p>
        </div>
    </footer>

    <script src="core/paywall.js"></script>
</body>
</html>
