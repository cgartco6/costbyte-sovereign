<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IdeaForge • Register / Login</title>
    <link rel="stylesheet" href="assets/sovereign.css">
</head>
<body class="login-page">
    <div class="login-container">
        <h1>FREE STARTUP LAUNCHER</h1>
        <p>Register once — your ideas stay private</p>
        
        <input type="text" id="username" placeholder="Your Name / Company" value="Alex Rivera">
        <input type="email" id="email" placeholder="Email (optional)" value="alex@example.com">
        
        <button onclick="performRegister()">REGISTER FREE &amp; CONTINUE</button>
        
        <p class="note">No credit card. No limits. Persistent session.</p>
    </div>

    <script src="core/auth.js"></script>
    <script>
        function performRegister() {
            const name = document.getElementById('username').value.trim() || "Founder";
            const email = document.getElementById('email').value.trim();
            login(name, "founder", email);
            window.location.href = "intake.html";
        }
    </script>
</body>
</html>
